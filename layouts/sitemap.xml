{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>\n<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n" | safeHTML }}
{{- range .Site.Pages }}
{{- if and (not (in .Permalink "/tags/")) (not (in .Permalink "/categories/")) (not (in .Permalink "/page/")) }}
{{- printf "  <url>\n    <loc>%s</loc>\n" .Permalink | safeHTML }}
{{- if not .Lastmod.IsZero }}
{{- printf "    <lastmod>%s</lastmod>\n" (.Lastmod.Format "2006-01-02") | safeHTML }}
{{- end }}
{{- with .Sitemap.ChangeFreq }}
{{- printf "    <changefreq>%s</changefreq>\n" . | safeHTML }}
{{- end }}
{{- with .Sitemap.Priority }}
{{- printf "    <priority>%.1f</priority>\n" . | safeHTML }}
{{- end }}
{{- printf "  </url>\n" | safeHTML }}
{{- end }}
{{- end }}
{{- printf "</urlset>\n" | safeHTML }}
