{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{ range .Site.Pages }}
  {{ if not (or (in .Permalink "/tags/") (in .Permalink "/categories/")) }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{ if not .Lastmod.IsZero }}<lastmod>{{ .Lastmod.Format "2006-01-02" }}</lastmod>{{ end }}
    {{ with .Sitemap.ChangeFreq }}<changefreq>{{ . }}</changefreq>{{ end }}
    {{ with .Sitemap.Priority }}<priority>{{ . }}</priority>{{ end }}
  </url>
  {{ end }}
  {{ end }}
</urlset>
